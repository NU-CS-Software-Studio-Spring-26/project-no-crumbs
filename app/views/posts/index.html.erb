<% content_for :title, "Meals" %>

<div class="page-hero d-flex justify-content-between align-items-center flex-wrap gap-3">
  <div>
    <h1>Meals</h1>
    <p>Spontaneous eats with your people</p>
  </div>
  <%= link_to new_post_path, class: "btn btn-light fw-bold" do %>
    <i class="bi bi-plus-lg me-1"></i> Plan a Meal
  <% end %>
</div>

<% if @posts.empty? %>
  <div class="empty-state">
    <div style="font-size:3.5rem">🍳</div>
    <p class="mt-3 mb-4 fs-5">No meals planned yet — be the first to start one.</p>
    <%= link_to "Plan a meal", new_post_path, class: "btn btn-fire" %>
  </div>
<% else %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% @posts.each do |post| %>
      <div class="col"><%= render post %></div>
    <% end %>
  </div>
<% end %>
