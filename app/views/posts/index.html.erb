<% content_for :title, "Meals" %>

<div class="feed-header">
  <div>
    <h1 class="feed-title">Meals</h1>
    <p class="feed-subtitle"><%= pluralize(@posts.count, "meal") %> planned</p>
  </div>
</div>

<% if @posts.empty? %>
  <div class="empty-state">
    <div class="empty-icon">🍽️</div>
    <p class="empty-title">Nothing on the menu yet</p>
    <p class="empty-sub">Be the first to plan something — your crew is hungry.</p>
    <%= link_to new_post_path, class: "btn-brand-nc" do %>
      <i class="bi bi-plus"></i> Plan a Meal
    <% end %>
  </div>
<% else %>
  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
    <% @posts.each do |post| %>
      <div class="col"><%= render post %></div>
    <% end %>
  </div>
<% end %>
