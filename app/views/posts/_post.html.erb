<div class="meal-card" id="<%= dom_id post %>">
  <div class="meal-cover gc-meal">
    <div class="meal-cover-date">
      <span class="day"><%= post.meal_date&.strftime("%-d") || "?" %></span>
      <span class="mon"><%= post.meal_date&.strftime("%b") || "—" %></span>
    </div>
  </div>

  <div class="meal-card-body">
    <h3 class="meal-card-title"><%= post.title %></h3>
    <div class="meal-card-when">
      <i class="bi bi-clock" style="font-size:0.75rem;color:var(--muted)"></i>
      <span><%= post.meal_date&.strftime("%a, %b %-d · %l:%M %p")&.strip || "Date TBD" %></span>
    </div>
    <% if post.description.present? %>
      <p class="meal-card-desc"><%= post.description %></p>
    <% end %>
  </div>

  <div class="meal-card-footer">
    <%= link_to post.user, class: "meal-host-link" do %>
      <div class="avatar avatar-sm"><%= post.user.username[0].upcase %></div>
      <span class="meal-host-name"><%= post.user.username %></span>
    <% end %>
    <%= link_to "View", post, class: "btn-outline-nc btn-sm-nc" %>
  </div>
</div>
