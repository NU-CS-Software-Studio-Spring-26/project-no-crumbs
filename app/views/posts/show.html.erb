<% content_for :title, @post.title %>

<%= link_to posts_path, class: "btn btn-sm btn-outline-secondary mb-3" do %>
  <i class="bi bi-arrow-left me-1"></i> Back to Meals
<% end %>

<div class="detail-hero mb-4">
  <div class="d-flex align-items-start gap-3">
    <div class="meal-date-block">
      <span class="day"><%= @post.meal_date&.strftime("%-d") || "?" %></span>
      <span class="mon"><%= @post.meal_date&.strftime("%b") || "—" %></span>
    </div>
    <div>
      <h1 class="fw-bold fs-3 mb-1"><%= @post.title %></h1>
      <p class="mb-0 opacity-75"><i class="bi bi-clock me-1"></i><%= @post.meal_date&.strftime("%A, %B %-d at %l:%M %p") %></p>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-8">
    <div class="bg-white rounded-3 border p-4 h-100" style="border-color:#F3EDE8 !important">
      <p class="section-eyebrow">About this meal</p>
      <p class="mb-0" style="color:#44403C"><%= @post.description.presence || "No description provided." %></p>
    </div>
  </div>
  <div class="col-md-4">
    <div class="bg-white rounded-3 border p-4 h-100" style="border-color:#F3EDE8 !important">
      <p class="section-eyebrow">Hosted by</p>
      <div class="d-flex align-items-center gap-2">
        <div class="avatar avatar-md"><%= @post.user.username[0].upcase %></div>
        <div>
          <%= link_to @post.user.username, @post.user, class: "fw-bold text-decoration-none text-dark d-block" %>
          <span class="text-muted small"><%= @post.user.email %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="d-flex gap-2">
  <%= link_to edit_post_path(@post), class: "btn btn-outline-secondary" do %>
    <i class="bi bi-pencil me-1"></i> Edit
  <% end %>
  <%= button_to @post, method: :delete, form: { data: { turbo_confirm: "Delete this meal?" } }, class: "btn btn-outline-danger" do %>
    <i class="bi bi-trash me-1"></i> Delete
  <% end %>
</div>
