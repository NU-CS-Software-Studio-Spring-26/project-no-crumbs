<% content_for :title, @post.title %>

<div class="mb-3">
  <%= link_to posts_path, class: "btn-outline-nc btn-sm-nc" do %>
    <i class="bi bi-arrow-left"></i> Meals
  <% end %>
</div>

<div class="detail-cover gc-meal">
  <div class="detail-cover-overlay"></div>
  <div class="detail-cover-content">
    <% if @post.meal_date %>
      <div class="detail-date-pill">
        <i class="bi bi-calendar3"></i>
        <%= @post.meal_date.strftime("%A, %B %-d") %>
      </div>
    <% end %>
    <h1 class="detail-title"><%= @post.title %></h1>
    <% if @post.meal_date %>
      <div class="detail-time-row">
        <i class="bi bi-clock"></i>
        <%= @post.meal_date.strftime("%l:%M %p").strip %>
      </div>
    <% end %>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-8">
    <div class="content-card h-100">
      <div class="content-card-header">
        <p class="content-card-label">About this meal</p>
      </div>
      <div class="content-card-body">
        <p style="color:var(--text-2);margin:0;line-height:1.75;font-size:0.9375rem">
          <%= @post.description.presence || "No description provided." %>
        </p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="content-card h-100">
      <div class="content-card-header">
        <p class="content-card-label">Hosted by</p>
      </div>
      <div class="content-card-body">
        <%= link_to @post.user, class: "d-flex align-items-center gap-3 text-decoration-none" do %>
          <div class="avatar avatar-md"><%= @post.user.username[0].upcase %></div>
          <div>
            <div style="font-weight:700;color:var(--text);font-size:0.9375rem;letter-spacing:-0.1px">
              <%= @post.user.username %>
            </div>
            <div style="font-size:0.8rem;color:var(--muted);margin-top:1px">
              <%= @post.user.email %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="d-flex gap-2 flex-wrap">
  <%= link_to edit_post_path(@post), class: "btn-outline-nc" do %>
    <i class="bi bi-pencil"></i> Edit
  <% end %>
  <%= button_to @post, method: :delete,
        form: { data: { turbo_confirm: "Delete this meal?" } },
        class: "btn-danger-nc" do %>
    <i class="bi bi-trash"></i> Delete
  <% end %>
</div>
