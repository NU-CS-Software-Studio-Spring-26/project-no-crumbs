<%= form_with(model: post) do |form| %>
  <% if post.errors.any? %>
    <div class="alert alert-danger mb-4">
      <strong><%= pluralize(post.errors.count, "error") %>:</strong>
      <ul class="mb-0 mt-1 ps-3">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-control", placeholder: "e.g. Backyard pasta night" %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.textarea :description, class: "form-control", rows: 4,
          placeholder: "What's on the menu? Any details to share?" %>
  </div>

  <div class="mb-3" data-controller="datepicker">
    <%= form.label :meal_date, "Date & Time", class: "form-label" %>
    <input type="text" data-datepicker-target="display" class="form-control"
           placeholder="e.g. May 10, 2026 at 7:00 PM" readonly style="cursor:pointer">
    <%= form.hidden_field :meal_date, data: { datepicker_target: "hidden" } %>
  </div>

  <%= form.submit class: "btn-nc" %>
<% end %>
