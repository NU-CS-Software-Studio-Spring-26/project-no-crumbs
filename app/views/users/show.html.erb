<% content_for :title, @user.username %>
<div class="mb-3">
  <%= link_to users_path, class: "btn-outline-nc btn-sm-nc" do %>
    <i class="bi bi-arrow-left"></i> People
  <% end %>
</div>

<div class="profile-card">
  <div class="profile-cover gc-meal"></div>

  <div class="profile-card-body">
    <div class="profile-avatar-row">
      <div class="avatar avatar-xl"><%= @user.username[0].upcase %></div>
      <div class="profile-actions">
        <%= link_to edit_user_path(@user), class: "btn-outline-nc btn-sm-nc" do %>
          <i class="bi bi-pencil"></i> Edit
        <% end %>
        <%= button_to @user, method: :delete,
              form: { data: { turbo_confirm: "Remove this person?" } },
              class: "btn-danger-nc btn-sm-nc" do %>
          <i class="bi bi-trash"></i>
        <% end %>
      </div>
    </div>

    <h2 class="profile-username"><%= @user.username %></h2>
    <p class="profile-email">
      <i class="bi bi-envelope" style="font-size:0.75rem"></i>
      <%= @user.email %>
    </p>
    <% if @user.bio.present? %>
      <p class="profile-bio"><%= @user.bio %></p>
    <% end %>
  </div>

  <div class="profile-stats-bar">
    <div class="profile-stat">
      <span class="profile-stat-num"><%= @user.posts.count %></span>
      <span class="profile-stat-label"><%= @user.posts.count == 1 ? "Meal" : "Meals" %></span>
    </div>
  </div>
</div>

<% if @user.posts.any? %>
  <p class="section-label">Meals hosted</p>
  <div class="nc-table-wrap">
    <table class="nc-table">
      <thead>
        <tr>
          <th>Meal</th>
          <th>Date</th>
          <th>Time</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @user.posts.each do |post| %>
          <tr>
            <td><%= post.title %></td>
            <td><%= post.meal_date&.strftime("%b %-d, %Y") || "—" %></td>
            <td><%= post.meal_date&.strftime("%-l:%M %p")&.strip || "—" %></td>
            <td class="text-end">
              <%= link_to "View", post, class: "btn-outline-nc btn-sm-nc" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p style="color:var(--muted);font-size:0.9rem;font-weight:500">No meals hosted yet.</p>
<% end %>
