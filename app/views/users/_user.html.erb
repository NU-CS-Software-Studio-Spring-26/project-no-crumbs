<div class="user-card" id="<%= dom_id user %>">
  <div class="user-card-body">
    <div class="avatar avatar-md mx-auto mb-3"><%= user.username[0].upcase %></div>
    <h5 class="fw-bold mb-1"><%= user.username %></h5>
    <p class="text-muted small mb-2"><%= user.email %></p>
    <% if user.bio.present? %>
      <p class="text-muted small mb-0" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden"><%= user.bio %></p>
    <% end %>
    <div class="mt-3">
      <span class="badge rounded-pill" style="background:#FFF0E8;color:#EA580C;font-size:0.75rem">
        <%= user.posts.count %> <%= user.posts.count == 1 ? "meal" : "meals" %>
      </span>
    </div>
  </div>
  <div class="user-card-footer">
    <%= link_to "View profile", user, class: "btn btn-sm btn-outline-secondary w-100" %>
  </div>
</div>
