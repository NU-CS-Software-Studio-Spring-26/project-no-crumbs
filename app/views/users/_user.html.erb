<div class="user-card" id="<%= dom_id user %>">
  <div class="user-cover gc-meal"></div>

  <div class="user-card-body">
    <div class="user-avatar-offset">
      <div class="avatar avatar-md"><%= user.username&.first&.upcase || "?" %></div>
    </div>

    <h5 class="user-card-name"><%= user.username %></h5>
    <p class="user-card-email"><%= user.email %></p>

    <% if user.bio.present? %>
      <p class="user-card-bio"><%= user.bio %></p>
    <% end %>

    <span class="tag tag-brand">
      <%= user.posts.count %> <%= user.posts.count == 1 ? "meal" : "meals" %>
    </span>
  </div>

  <div class="user-card-footer">
    <%= link_to "View profile", user, class: "btn-outline-nc w-100 justify-content-center" %>
  </div>
</div>
