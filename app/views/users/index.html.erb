<% content_for :title, "People" %>

<div class="page-hero d-flex justify-content-between align-items-center flex-wrap gap-3">
  <div>
    <h1>Friends</h1>
    <p>Friends who eat together, stay together</p>
  </div>
  <%= link_to new_user_path, class: "btn btn-light fw-bold" do %>
    <i class="bi bi-plus-lg me-1"></i> Add Someone
  <% end %>
</div>

<% if @users.empty? %>
  <div class="empty-state">
    <div style="font-size:3.5rem">👥</div>
    <p class="mt-3 mb-4 fs-5">No one here yet — add your first friend.</p>
    <%= link_to "Add someone", new_user_path, class: "btn btn-fire" %>
  </div>
<% else %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% @users.each do |user| %>
      <div class="col"><%= render user %></div>
    <% end %>
  </div>
<% end %>
