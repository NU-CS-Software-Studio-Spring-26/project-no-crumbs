<% content_for :title, "People" %>

<div class="feed-header">
  <div>
    <h1 class="feed-title">People</h1>
    <p class="feed-subtitle"><%= pluralize(@users.count, "person") %> in the crew</p>
  </div>
</div>

<% if @users.empty? %>
  <div class="empty-state">
    <div class="empty-icon">👤</div>
    <p class="empty-title">No one here yet</p>
    <p class="empty-sub">Add your first friend and start planning meals together.</p>
    <%= link_to new_user_path, class: "btn-brand-nc" do %>
      <i class="bi bi-plus"></i> Add Someone
    <% end %>
  </div>
<% else %>
  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
    <% @users.each do |user| %>
      <div class="col"><%= render user %></div>
    <% end %>
  </div>
<% end %>
