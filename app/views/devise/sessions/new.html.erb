<% content_for :title, "Log in" %>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-brand-strip gc-meal"></div>
    <div class="auth-card-body">
      <div class="auth-logo">
        <%= link_to root_path, class: "nc-brand" do %>No<span>Crumbs</span><% end %>
      </div>
      <h1 class="auth-title">Welcome back</h1>
      <p class="auth-sub">Log in to see what's cooking.</p>

      <% if alert.present? && alert != I18n.t('devise.failure.unauthenticated') %>
        <div class="auth-errors">
          <i class="bi bi-exclamation-circle-fill"></i>
          <div><p><%= alert %></p></div>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
        </div>

        <div class="mb-4">
          <%= f.label :password, class: "form-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="mb-3 d-flex align-items-center gap-2">
            <%= f.check_box :remember_me, class: "form-check-input" %>
            <%= f.label :remember_me, class: "auth-check-label" %>
          </div>
        <% end %>

        <%= f.submit "Log in", class: "btn-brand-nc w-100" %>
      <% end %>

      <div class="auth-links">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
