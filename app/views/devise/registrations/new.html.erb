<% content_for :title, "Sign up" %>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-brand-strip gc-meal"></div>
    <div class="auth-card-body">
      <div class="auth-logo">
        <%= link_to root_path, class: "nc-brand" do %>No<span>Crumbs</span><% end %>
      </div>
      <h1 class="auth-title">Join the table</h1>
      <p class="auth-sub">Create an account and start planning meals.</p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="mb-3">
          <%= f.label :username, class: "form-label" %>
          <%= f.text_field :username, autofocus: true, autocomplete: "username", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
        </div>

        <div class="mb-3">
          <div class="d-flex align-items-baseline gap-2">
            <%= f.label :password, class: "form-label mb-0" %>
            <% if @minimum_password_length %>
              <span class="auth-hint"><%= @minimum_password_length %> chars min</span>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control mt-1" %>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, class: "form-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <%= f.submit "Create account", class: "btn-brand-nc w-100" %>
      <% end %>

      <div class="auth-links">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
